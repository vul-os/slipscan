# Slipscan environment template.
#
# Copy to one of:
#   .env       — local development (loaded by default; gitignored)
#   .env.dev   — dev/staging (loaded with APP_ENV=dev or `vite --mode dev`)
#   .env.main  — production  (loaded with APP_ENV=main or `vite --mode main`)
#
# Migrate selects the file via `cmd/migrate --env=local|dev|main`.
# The backend server selects via APP_ENV; defaults to .env.

# ---------- Database ----------
# Neon connection string for dev/main, or local Postgres for .env.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slipscan?sslmode=disable

# ---------- Auth ----------
# 32+ chars. Generate with:  openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
INVITATION_TTL=168h

# ---------- HTTP ----------
PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------- Frontend (Vite) ----------
# Only VITE_* vars are exposed to the browser bundle.
VITE_API_URL=http://localhost:8080

# ---------- Storage (Backblaze B2, S3-compatible) ----------
# Bucket-scoped (non-master) key from https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# ---------- Storage — generic S3-compatible override (Cloudflare R2 / any S3) ----------
# These vars take precedence over B2_* when set, so you can migrate to R2
# (or any other S3-compatible backend) without touching the existing B2_* vars.
#
# Cloudflare R2 example:
#   STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   STORAGE_KEY_ID=<R2 access key id>
#   STORAGE_SECRET=<R2 secret access key>
#   STORAGE_BUCKET=<bucket name>
#   STORAGE_REGION=auto   (R2 ignores region; "auto" is the conventional value)
#
# Leave blank to fall back to the B2_* vars above.
STORAGE_ENDPOINT=
STORAGE_KEY_ID=
STORAGE_SECRET=
STORAGE_BUCKET=
STORAGE_REGION=

# ---------- AI / LLM ----------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---------- Email (Amazon SES + outbox queue) ----------
# When EMAIL_FROM and AWS_REGION are both set, the app sends via SES through
# a Postgres outbox queue.  When either is blank, email is disabled gracefully
# (NoopSender) — invitation links still work; the admin shares them manually.
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Verified SES identity; must be a domain/address confirmed in the SES console.
EMAIL_FROM=slip/scan <noreply@mail.slipscan.app>
# Optional: SES configuration set for open/click/bounce tracking.
SES_CONFIGURATION_SET=
# IMPORTANT — single-runner guard:
# Set EMAIL_WORKER_ENABLED=true on EXACTLY ONE fleet VM.  If multiple VMs
# run the worker simultaneously, the SKIP LOCKED claim prevents duplicate
# sends, but the extra DB polling is wasteful.  Leave it unset (or false) on
# all secondary instances.
EMAIL_WORKER_ENABLED=false
# Optional: polling interval for the outbox worker (default 5s).
# EMAIL_WORKER_INTERVAL=5s

# ---------- Inbound mail receiver (cmd/mailrx) ----------
# The domain part of inbound addresses: <org-slug>@RX_DOMAIN.
# Must match your MX record. Set to localhost or any domain in dev.
RX_DOMAIN=mail.slipscan.app
# TCP address the SMTP server binds. Port 25 requires root; use 2525 locally.
MAILRX_ADDR=:2525
# Hard cap on inbound message size in bytes (default 25 MB = 26214400).
MAILRX_MAX_MESSAGE_BYTES=26214400
# Comma-separated list of allowed attachment MIME types (leave blank for defaults).
# Default: application/pdf,image/jpeg,image/png,image/heic,image/heif
# MAILRX_ALLOWED_TYPES=

# ---------- HTTP inbound-email ingest (Cloudflare Email Worker bridge) ----------
# When INBOUND_INGEST_SECRET is set, the route POST /internal/inbound-email is
# enabled.  Cloudflare Email Workers (or any trusted caller) POST raw RFC 822
# messages here instead of delivering via SMTP port 25.
#
# Contract:
#   POST /internal/inbound-email?recipient=<org-slug>
#   Header: X-Inbound-Secret: <this value>
#   Content-Type: message/rfc822
#   Body: raw RFC 822 bytes (max MAILRX_MAX_MESSAGE_BYTES)
#   → 202 Accepted on success; 401 bad secret; 400 bad request; 5xx retry
#
# Leave blank (or unset) to disable the route entirely (returns 404).
# Generate with:  openssl rand -hex 32
INBOUND_INGEST_SECRET=

# ---------- Exchange rates ----------
# Hourly cron — fetches FX rates into fx_rates, at most 24 times/day.
#
# Provider: defaults to frankfurter.app (free, no key, ECB data, covers ZAR).
# To use exchangerate-api.com instead, set EXCHANGE_RATE_API_KEY.
#
# IMPORTANT — single-runner guard:
# Set FX_SYNC_ENABLED=true on EXACTLY ONE fleet VM. If all VMs set it,
# you will get 24 × N calls/day (N = number of VMs), which breaks free-tier
# limits. Leave it unset (or set to false) on all secondary instances.
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_BASE=USD
FX_SYNC_ENABLED=false

# ---------- Frontend (Vite — Cloudflare Pages build vars) ----------
# Consumed by the SPA at build time (src/lib/api.js, pages/Onboarding, Settings).
# Only VITE_-prefixed keys are exposed to the client bundle. Set these per build
# mode in .env.dev / .env.main (shared with the backend; Vite ignores non-VITE keys).
# VITE_API_URL=https://api.slipscan.app
# VITE_RX_DOMAIN=mail.slipscan.app
