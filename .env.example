# Postgres connection string. For local dev with the docker-compose service
# this is typically postgres://postgres:postgres@localhost:5432/slipscan
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slipscan?sslmode=disable

# 32+ chars. Generate with:  openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars

# Access tokens are short-lived; refresh tokens are long-lived.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# How long a fresh invitation link stays valid.
INVITATION_TTL=168h

PORT=8080

# Used to build invitation accept URLs in emails.
APP_BASE_URL=http://localhost:8080

# Comma-separated list of allowed origins, or "*" for permissive dev.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vite) — base URL the React app uses to call the API.
VITE_API_URL=http://localhost:8080

# Backblaze B2 (S3-compatible) — receipt/slip storage.
# Create a bucket-scoped (non-master) key at https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# Google Gemini — AI extraction LLM.
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
