{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlipScan",
  "version": "0.1.0",
  "identifier": "org.vulos.slipscan",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "slip/scan",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis", "appimage", "deb"],
    "category": "Finance",
    "publisher": "Vulos",
    "copyright": "© 2026 Vulos. MIT License.",
    "shortDescription": "Self-hosted personal finance and accounting",
    "longDescription": "slip/scan — self-hosted personal finance and accounting. Local-first: embedded SQLite, no telemetry, no default network calls.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "section": "utils"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
