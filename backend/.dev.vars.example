# Worker environment template. Copy to `.dev.vars` for LOCAL `wrangler dev`
# (gitignored). For the DEPLOYED worker these are set differently:
#   - secrets  -> `wrangler secret put <NAME>`   (DATABASE_URL, JWT_SECRET,
#                 GEMINI_API_KEY, INBOUND_INGEST_SECRET, RESEND_API_KEY,
#                 GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET)
#   - non-secret vars -> wrangler.toml [vars]    (RESEND_FROM, GOOGLE_REDIRECT_URL,
#                 RX_DOMAIN, FRONTEND_BASE_URL, APP_BASE_URL, EXCHANGE_RATE_BASE)
#
# ─── Core (required) ───────────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<pass>@<host>/<db>?sslmode=require
JWT_SECRET=<32+ char secret>
GEMINI_API_KEY=<google ai studio key>

# ─── Inbound email ingest (Email Worker bridge) ────────────────────
INBOUND_INGEST_SECRET=<openssl rand -hex 32>

# ─── Outbound email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM=slip/scan <noreply@your-verified-domain>

# ─── Google sign-in (OAuth2) ───────────────────────────────────────
# Redirect URIs to register in the Google OAuth client (one per environment):
#   local : http://localhost:8787/auth/google/callback
#   prod  : https://slipscan-api.slipscanco.workers.dev/auth/google/callback
#   custom: https://api.slipscan.com/auth/google/callback   (once the domain is on CF)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8787/auth/google/callback

# ─── R2 (storage) is a binding in wrangler.toml — no env var needed locally ──
