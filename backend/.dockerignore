# .dockerignore — files excluded from the Docker build context.
# The builder stage only needs Go source; everything else is noise.

# Local env / secrets — never copy these into the image.
.env
.env.*
!.env.example

# Dev tooling and generated artefacts.
bin/
*.bin
*.test

# Documentation and scripts not needed at build time.
docs/
scripts/
ARCHITECTURE.md
DEPLOY.md
README.md
Makefile

# Test fixtures that could be large.
testdata/

# OS artefacts.
.DS_Store
Thumbs.db
